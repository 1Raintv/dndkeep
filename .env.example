# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (public key only — secret key goes on the server/edge function)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Price IDs
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_your-price-id-here

# App
VITE_APP_URL=http://localhost:5173

# Optional — Giphy (campaign chat GIF picker). Leave unset to hide
# the GIF button entirely. Free key from developers.giphy.com.
# VITE_GIPHY_API_KEY=your-giphy-key-here
